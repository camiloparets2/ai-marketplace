# NOTE: .env.local.example is the maintained template (includes the eBay
# production annotations). This file is kept for older doc links.
# Copy to .env.local for local dev. Set the same keys in the Vercel env panel
# for production. Never commit real values.

# ── Core ──────────────────────────────────────────────────────────────────────
# Claude Vision extraction
ANTHROPIC_API_KEY=
# Public URL of the deployed app — used to build OAuth redirect URIs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Random secret for Vercel Cron. When set, Vercel calls /api/sync/orders
# (daily order-sync sweep, see vercel.json) with Authorization: Bearer <this>.
CRON_SECRET=

# ── Supabase (auth + token store + listing photo hosting) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Anon key — client-safe; powers sign-in (email/password + Google via
# Supabase Auth). Enable the Google provider in Supabase → Authentication.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server-only; used for marketplace token storage and photo
# hosting. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (subscriptions + direct payment links) ─────────────────────────────
STRIPE_SECRET_KEY=
# Signing secret of the Stripe webhook endpoint pointed at
# {NEXT_PUBLIC_APP_URL}/api/billing/webhook — required for subscriptions to
# sync and monthly credits to be granted. Events to send: checkout.session.
# completed, customer.subscription.*, invoice.paid, invoice.payment_failed.
STRIPE_WEBHOOK_SECRET=

# ── eBay (live publishing via Sell Inventory API) ─────────────────────────────
# Keyset from developer.ebay.com → Application Keys
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# The RuName tied to your OAuth "accepted" URL, which must point to
# {NEXT_PUBLIC_APP_URL}/api/oauth/ebay/callback — or the registered alias
# /api/ebay/oauth/callback (both are served; see next.config.ts rewrites).
# EBAY_RUNAME (no underscore) is accepted as an alias for this variable.
EBAY_RU_NAME=
# "production" (default) or "sandbox" — case-insensitive. The Production
# keyset is enabled; set "sandbox" explicitly for sandbox testing (note the
# sandbox Cert ID was rotated 2026-07-04 — refresh EBAY_CLIENT_SECRET when
# switching to sandbox).
EBAY_ENV=production
# SAFETY: the auto-list pipeline (/api/pipeline) only publishes to PRODUCTION
# eBay when this is exactly "true". Off (default) → dry run: the payload is
# built, nothing is posted. Sandbox publishes ignore this flag. Leave OFF
# until the pipeline has passed a supervised sandbox run.
PIPELINE_LIVE_PUBLISH=false
# DEPRECATED — ship-from is per-user now (docs/design/ship-from-location.md):
# auto-detected from the seller's eBay account at connect time, or collected
# once via /settings/ship-from. Kept only as a US-only local-dev fallback;
# do not set in production.
# EBAY_POSTAL_CODE=
# Optional: pin specific business policies instead of using the account's first
# EBAY_FULFILLMENT_POLICY_ID=
# EBAY_PAYMENT_POLICY_ID=
# EBAY_RETURN_POLICY_ID=

# ── Shopify (live publishing via REST Admin API) ──────────────────────────────
# App credentials from partners.shopify.com (or a custom app). The app's
# allowed redirection URL must be
# {NEXT_PUBLIC_APP_URL}/api/oauth/shopify/callback
# Scopes requested: write_products, read_orders.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ── Etsy (live publishing via Open API v3) ────────────────────────────────────
# App keystring from etsy.com/developers (ETSY_CLIENT_ID accepted as an alias).
# The app's redirect URI must be {NEXT_PUBLIC_APP_URL}/api/oauth/etsy/callback,
# or set ETSY_REDIRECT_URI to whatever URI is registered with Etsy (the alias
# /api/etsy/oauth/callback is also served; see next.config.ts rewrites).
ETSY_API_KEY=
# ETSY_REDIRECT_URI=
# Required Etsy attribution fields for created listings (defaults shown)
# ETSY_WHO_MADE=someone_else
# ETSY_WHEN_MADE=2010_2019

# ── eBay Marketplace Account Deletion notifications (required for Production) ──
# Endpoint: {NEXT_PUBLIC_APP_URL}/api/ebay/account-deletion
# A secret you invent (32–80 chars, letters/numbers/_/- only). Paste the SAME
# value into eBay Developer Portal → Alerts & Notifications → verification token.
EBAY_MARKETPLACE_DELETION_VERIFICATION_TOKEN=
# The exact public HTTPS URL eBay is configured to call — must match byte-for-byte
# (e.g. https://your-app.vercel.app/api/ebay/account-deletion)
EBAY_MARKETPLACE_DELETION_ENDPOINT=

# ── eBay order notifications (push half of sold-item sync) ────────────────────
# Endpoint: {NEXT_PUBLIC_APP_URL}/api/webhooks/ebay-orders
# Same challenge scheme as account deletion, with its OWN token pair. Configure
# in eBay Developer Portal → Alerts & Notifications (order topics).
EBAY_ORDER_WEBHOOK_VERIFICATION_TOKEN=
EBAY_ORDER_WEBHOOK_ENDPOINT=
